#include<stdio.h>
int main()
{
    int x,y,sum=0,i;

    scanf("%d\n%d",&x,&y);

    if(y>x)
    {
        for(i=x;i<=y;i++)
        {
            if(i%13!=0)
            {
                sum=sum+i;
            }
        }
    }
    else
    {
        for(i=y;i<=x;i++)
        {
            if(i%13!=0)
            {
                sum=sum+i;
            }
        }
    }
    printf("%d\n",sum);

    return 0;
}
