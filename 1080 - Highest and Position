#include<stdio.h>
int main()
{
    int num[100],i,a=1,max;

    for(i=0; i<100; i++)
    {
        scanf("%d",&num[i]);
    }
    max=num[0];
    for(i=1; i<100; i++)
    {
        if(max < num[i])
        {
            max=num[i];
            a=i+1;
        }
    }
    printf("%d\n",max);
    printf("%d\n",a);

    return 0;

}
