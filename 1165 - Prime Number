#include<stdio.h>
int main()
{
    int n,i,c,j,m;

    scanf("%d",&m);
    for(j=1; j<=m; j++)
    {
        c=0;
        scanf("%d",&n);

        for(i=2; i<n; i++)
        {
            if(n%i==0)
            {
                c++;
                break;
            }
        }
        if(c==0)
        {
            printf("%d eh primo\n",n);
        }
        else
        {
            printf("%d nao eh primo\n",n);
        }
    }
    return 0;
}
