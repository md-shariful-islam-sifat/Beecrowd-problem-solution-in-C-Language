#include<stdio.h>
int main()
{
    int i,min,a=0,n;

    scanf("%d\n",&n);

    int num[n];
    for(i=0; i<n; i++)
    {
        for(i=0; i<n; i++)
        {
            scanf("%d",&num[i]);
        }

        min=num[0];

        for(i=1; i<n; i++)
        {
            if(min > num[i])
            {
                min=num[i];
                a=i;
            }
        }
        printf("Menor valor: %d\n",min);
        printf("Posicao: %d\n",a);
    }
    return 0;
}
