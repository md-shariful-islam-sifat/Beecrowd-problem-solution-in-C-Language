#include<stdio.h>
int main()
{
    int n,a[46],i;

    scanf("%d",&n);

    if(n<46 && n>0)
    {
        a[0]=0;
        a[1]=1;

        for(i=2; i<n; i++)
        {
            a[i]=a[i-1]+a[i-2];
        }

        for(i=0; i<n; i++)
        {
            printf("%d",a[i]);
            if(i!=n-1)
            {
                printf(" ");
            }
        }
        printf("\n");
    }
    return 0;
}
