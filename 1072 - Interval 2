#include<stdio.h>
int main()
{
    int i,m,n,in=0,out=0;

    scanf("%d",&m);

    for(i=1;i<=m;i++)
    {
        scanf("%d",&n);

        if(n>=10 && n<=20)
        {
            in++;
        }
        else
        {
            out++;
        }
    }
    printf("%d in\n",in);
    printf("%d out\n",out);

    return 0;
}
