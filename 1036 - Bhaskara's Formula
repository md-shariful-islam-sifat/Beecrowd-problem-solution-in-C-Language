#include<stdio.h>
int main()
{
    double a,b,c,R1,R2,x,y;

    scanf("%lf %lf %lf",&a,&b,&c);

    y=b*b-(4*a*c);
    x=sqrt(y);

    if(y<0 || a==0)
    {
        printf("Impossivel calcular\n");
    }
    else
    {
        R1=(-b+x)/(2*a);

        R2=(-b-x)/(2*a);

        printf("R1 = %.5lf\n",R1);

        printf("R2 = %.5lf\n",R2);
    }

    return 0;
}
